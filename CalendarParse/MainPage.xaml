<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalendarParse.MainPage"
             Title="CalendarParse">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <!-- ── Controls ───────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button x:Name="CameraBtn"
                        Text="📷  Take Photo"
                        Clicked="OnCameraClicked"
                        HorizontalOptions="Fill" />
                <Button x:Name="ImportBtn"
                        Text="🖼  Import"
                        Clicked="OnImportClicked"
                        HorizontalOptions="Fill" />
                <Button x:Name="ProcessBtn"
                        Text="⚙  Process"
                        Clicked="OnProcessClicked"
                        IsEnabled="False"
                        HorizontalOptions="Fill" />
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="File"
                       VerticalOptions="Center"
                       FontSize="14" />
                <Label Grid.Column="1"
                       x:Name="FileNameLabel"
                       Text="No file selected"
                       VerticalOptions="Center"
                       FontSize="14"
                       TextColor="{StaticResource Gray500}"
                       LineBreakMode="TailTruncation" />
            </Grid>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="Search Name"
                       VerticalOptions="Center"
                       FontSize="14" />
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Placeholder="Filter by employee name"
                       ClearButtonVisibility="WhileEditing" />
            </Grid>

            <ActivityIndicator x:Name="Spinner"
                               IsRunning="False"
                               IsVisible="False"
                               HorizontalOptions="Center" />

            <Label x:Name="StatusLabel"
                   Text=""
                   FontSize="13"
                   TextColor="{StaticResource Gray500}"
                   HorizontalOptions="Center"
                   IsVisible="False" />
        </VerticalStackLayout>

        <!-- ── Results ───────────────────────────────────────── -->
        <ScrollView Grid.Row="1" Margin="0,12,0,0">
            <Label x:Name="ResultLabel"
                   Text=""
                   FontFamily="Courier New"
                   FontSize="12"
                   LineBreakMode="WordWrap" />
        </ScrollView>

    </Grid>

</ContentPage>

