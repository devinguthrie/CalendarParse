<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CalendarParse.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CalendarParse"
    xmlns:pages="clr-namespace:CalendarParse.Pages"
    Title="CalendarParse">

    <TabBar>
        <Tab Title="Schedule">
            <ShellContent
                Title="Schedule"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Monitor">
            <ShellContent
                Title="Monitor"
                ContentTemplate="{DataTemplate pages:MonitorSetupPage}"
                Route="MonitorSetupPage" />
        </Tab>

        <Tab Title="History">
            <ShellContent
                Title="History"
                ContentTemplate="{DataTemplate pages:HistoryPage}"
                Route="HistoryPage" />
        </Tab>

        <Tab Title="Settings">
            <ShellContent
                Title="Settings"
                ContentTemplate="{DataTemplate pages:SettingsPage}"
                Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>
